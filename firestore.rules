// Reglas SOLO para las colecciones de Olimpo (prefijo olimpo_). No tocan
// las reglas existentes del ajedrez — Jose: pega este bloque dentro de tus
// reglas actuales en Firebase Console > Firestore Database > Reglas,
// agregándolo junto a lo que ya tengas (no reemplaces todo el archivo).
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Personajes: cualquiera puede leer (para saber quién está tomado),
    // pero solo se puede crear una vez (claim) y nunca se puede pisar el
    // pinHash de otro — el cambio de pinHash solo lo hace quien ya lo sabe
    // (verificado client-side antes de escribir; ver SPEC.md sección admin
    // para el endurecimiento server-side con Cloud Functions en v1.2).
    match /olimpo_personajes/{name} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAll(['pinHash','claimedAt'])
                    && request.resource.data.pinHash is string;
      allow update: if resource.data.pinHash == request.resource.data.pinHash
                    || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lastSeen']);
      allow delete: if false;
    }

    // Mensajes del tablero: cualquiera lee, cualquiera escribe (texto corto,
    // moderación manual por Jose desde la consola de Firebase mientras no
    // exista el panel de admin — v1.2).
    match /olimpo_mensajes/{msgId} {
      allow read: if true;
      allow create: if request.resource.data.text is string
                    && request.resource.data.text.size() <= 200
                    && request.resource.data.who is string;
      allow update, delete: if false;
    }
  }
}
